<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Rango_Score_Crediticio</fullName>
    <active>true</active>
    <errorConditionFormula>OR(
    Score_Crediticio_Butro__c &lt; 0,
    Score_Crediticio_Butro__c &gt; 10
)</errorConditionFormula>
    <errorDisplayField>Score_Crediticio_Butro__c</errorDisplayField>
    <errorMessage>El Score Crediticio debe ser un número entre 0 y 10.</errorMessage>
</ValidationRule>
