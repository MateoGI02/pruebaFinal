<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Antiguedad_Laboral_Mayor_A_Cero</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Antiguedad_Laboral_en_Meses__c)),
    Antiguedad_Laboral_en_Meses__c &lt;= 0
)</errorConditionFormula>
    <errorDisplayField>Antiguedad_Laboral_en_Meses__c</errorDisplayField>
    <errorMessage>La Antigüedad Laboral debe ser mayor a 0 meses.</errorMessage>
</ValidationRule>
